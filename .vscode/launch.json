{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pure Live Windows Release",
            "request": "launch",
            "type": "dart",
            "deviceId": "windows",
            "flutterMode": "release",
            "args": [
                "-v"
            ],
            "env": {
                "http_proxy": "http://127.0.0.1:7890",
                "https_proxy": "http://127.0.0.1:7890",
                "HTTP_PROXY": "http://127.0.0.1:7890",
                "HTTPS_PROXY": "http://127.0.0.1:7890"
            }
        }
    ]
}
